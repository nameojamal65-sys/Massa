#!/bin/bash

# دالة فحص الحالة
check_deploy_status() {
    echo "[*] جاري فحص حالة الأتمتة على GitHub..."
    TOKEN=$(cat .github_token 2>/dev/null)
    if [ -z "$TOKEN" ]; then
        echo "[!] خطأ: ملف .github_token فارغ أو غير موجود."
        return
    fi
    
    curl -s -H "Authorization: token $TOKEN" \
         https://api.github.com/repos/nameojamal65-sys/Massa/actions/runs \
         | jq -r '.workflow_runs[0] | "الحالة: \(.status) | النتيجة: \(.conclusion)"'
}

# القائمة الرئيسية
echo "=============================="
echo "      MASA ALL-IN-ONE ENGINE"
echo "=============================="
echo "1) رفع التحديثات (Git Push & Auto-Deploy)"
echo "2) فحص حالة البناء (GitHub Status)"
echo "3) خروج"
echo "=============================="
read -p "[?] اختر العملية (1-3): " choice

case $choice in
    1)
        git add .
        read -p "أدخل رسالة التعديل (Commit message): " msg
        git commit -m "${msg:-Auto-Update $(date)}"
        git push
        echo "[✓] تم رفع الكود، الأتمتة تعمل الآن في الخلفية على GitHub!"
        ;;
    2)
        check_deploy_status
        ;;
    3)
        exit
        ;;
    *)
        echo "[!] اختيار خاطئ."
        ;;
esac
